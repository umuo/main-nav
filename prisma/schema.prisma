// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Website {
  id               String  @id @default(uuid())
  title            String
  url              String
  description      String?
  iconUrl          String?
  status           String  @default("unknown")
  lastChecked      BigInt  @default(0)
  latency          Int?
  serverStatusCode Int?
  serverReason     String?
  categoryId       String?

  category Category? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

model Category {
  id       String    @id @default(uuid())
  name     String
  websites Website[]
}

model Config {
  key   String @id
  value String
}

model LoginThrottle {
  key             String @id
  failures        Int    @default(0)
  windowStartedAt BigInt
  blockedUntil    BigInt @default(0)
  updatedAt       BigInt

  @@index([updatedAt])
}
