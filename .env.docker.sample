# docker-compose 环境变量模板
# 复制为 .env 后填写真实值：cp .env.docker.sample .env

# ---- 数据库（compose 中 db 服务） ----
DB_PASSWORD=change-me-to-a-strong-password
DATABASE_POOL_MAX=3

# ---- 管理员账号 ----
ADMIN_USERNAME=admin
# 生成方式：node scripts/generate-password.mjs '你的强密码'
ADMIN_PASSWORD_HASH=replace-with-output-from-generate-password-script
# 生成方式：openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-characters

# ---- Agent/CLI 管理 API（可选，至少 32 字符；不需要可删除本行） ----
# 调用方通过 Authorization: Bearer <token> 访问管理接口
# 生成方式：openssl rand -base64 32
# ADMIN_API_TOKEN=replace-with-at-least-32-random-characters

# ---- Cloudflare Turnstile（可选，留空则使用官方测试密钥） ----
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
# TURNSTILE_SECRET_KEY=your-secret-key
# TURNSTILE_ALLOWED_HOSTNAMES=nav.example.com

# ---- 反向代理（如经过 Nginx/Caddy，置为 true） ----
TRUST_PROXY_HEADERS=false
